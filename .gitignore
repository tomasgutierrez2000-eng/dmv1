# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.js
.npm-cache
.npm-logs

# testing
/coverage
scripts/output/

# generated SQL exports
sql/exports/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# agent suite audit logs (session JSON files, not the DDL or logger)
.claude/audit/sessions/*.json
.claude/audit/schema-changes/*.json
.claude/config/schema-manifest.yaml
