[
  {
    "item_id": "MET-108",
    "item_name": "Interest Expense",
    "abbreviation": "INT_EXP",
    "kind": "METRIC",
    "definition": "Total interest cost incurred on funding sources attributable to the reporting unit during the period. At facility level, computed as the product of the committed amount, the bank's participation share, and the cost of funds rate. At higher rollup levels, aggregated as the sum of facility-level interest expense.",
    "generic_formula": "committed_facility_amt × bank_share_pct × cost_of_funds_rate",
    "data_type": "NUMERIC(20,4)",
    "unit_type": "CURRENCY",
    "direction": "LOWER_BETTER",
    "metric_class": "CALCULATED",
    "domain_ids": [
      "profitability"
    ],
    "regulatory_references": [
      "FR Y-14Q Schedule H"
    ],
    "insight": "Funding cost burden and margin compression risk. Rising interest expense without corresponding income growth signals deteriorating net interest margin.",
    "number_of_instances": 5,
    "directly_displayed": false,
    "status": "ACTIVE",
    "executable_metric_id": "PROF-108",
    "normalized_de_name": "Interest Expense",
    "data_element_in_dm": "interest_expense_amt",
    "ingredient_fields": [
      {
        "layer": "L1",
        "table": "facility_master",
        "field": "committed_facility_amt",
        "description": "Total committed amount of the facility",
        "data_type": "NUMERIC(20,4)",
        "sample_value": "50000000"
      },
      {
        "layer": "L1",
        "table": "facility_lender_allocation",
        "field": "bank_share_pct",
        "description": "Bank's participation share of the facility (%)",
        "data_type": "NUMERIC(10,4)",
        "sample_value": "60"
      },
      {
        "layer": "L2",
        "table": "facility_pricing_snapshot",
        "field": "cost_of_funds_pct",
        "description": "Cost of funds rate for the facility (derived as all_in_rate minus spread)",
