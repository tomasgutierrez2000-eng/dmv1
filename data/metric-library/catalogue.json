  {
    "item_id": "EAD",
    "item_name": "Exposure at Default",
    "abbreviation": "EAD",
    "kind": "METRIC",
    "definition": "Estimated credit exposure if the counterparty defaults. For drawn facilities: outstanding balance. For undrawn: drawn + CCF * (committed - drawn). Fundamental input to Expected Loss (EL = PD x LGD x EAD) and regulatory capital calculations under Basel III IRB.",
    "generic_formula": "drawn_amount + ccf * (committed_amount - drawn_amount)",
    "data_type": "Decimal",
    "unit_type": "CURRENCY",
    "direction": "LOWER_BETTER",
    "metric_class": "HYBRID",
    "domain_ids": [
      "EL",
      "CR"
    ],
    "regulatory_references": [
      "Basel III IRB",
      "FR Y-14Q"
    ],
    "insight": "Estimated credit exposure if the counterparty defaults",
    "ingredient_fields": [
      {
        "layer": "L2",
        "table": "facility_exposure_snapshot",
        "field": "drawn_amount",
        "description": "Current drawn balance",
        "data_type": "DECIMAL(18,2)",
        "sample_value": "5000000.00"
      },
      {
        "layer": "L2",
        "table": "facility_exposure_snapshot",
        "field": "undrawn_amount",
        "description": "Undrawn commitment amount",
        "data_type": "DECIMAL(18,2)",
        "sample_value": "2000000.00"
      },
      {
        "layer": "L1",
        "table": "facility_master",
        "field": "committed_facility_amt",
        "description": "Total authorized credit line",
        "data_type": "DECIMAL(18,2)",
        "sample_value": "7000000.00"
      },
      {
        "layer": "L2",
        "table": "facility_risk_snapshot",
        "field": "ccf",
        "description": "Credit conversion factor for undrawn exposure",
        "data_type": "DECIMAL(6,4)",
        "sample_value": "0.45"
      },
      {
        "layer": "L1",
        "table": "facility_master",
        "field": "counterparty_id",
        "description": "FK to counterparty",
        "data_type": "BIGINT",
        "sample_value": "67890"
      },
      {
        "layer": "L1",
        "table": "facility_master",
        "field": "lob_segment_id",
        "description": "FK to enterprise_business_taxonomy",
        "data_type": "BIGINT",
        "sample_value": "303"
      }
    ],
    "level_definitions": [
      {
        "level": "facility",
        "dashboard_display_name": "Facility EAD ($)",
        "in_record": true,
        "sourcing_type": "Calc",
        "level_logic": "For each DISTINCT(facility_id) THEN [drawn_amount] + [ccf] * ([committed_facility_amt] - [drawn_amount])",
        "source_references": []
      },
      {
        "level": "counterparty",
        "dashboard_display_name": "Counterparty EAD ($)",
        "in_record": true,
        "sourcing_type": "Agg",
        "level_logic": "For each [counterparty_id] THEN SUM(facility.ead) WHERE IS([counterparty_id])",
        "source_references": []
      },
      {
        "level": "desk",
        "dashboard_display_name": "Desk EAD ($)",
        "in_record": true,
        "sourcing_type": "Agg",
        "level_logic": "For each [L3 Business Segment], lookup [lob_segment_id] from enterprise_business_taxonomy WHERE [tree_level]='L3'. SUM(facility.ead) for all facilities WHERE IS([lob_segment_id])",
        "source_references": []
      },
      {
        "level": "portfolio",
        "dashboard_display_name": "Portfolio EAD ($)",
        "in_record": true,
        "sourcing_type": "Agg",
        "level_logic": "For each [L2 Business Segment], SUM(facility.ead) for all facilities under L2 segment including all child L3 segments via parent_segment_id traversal",
        "source_references": []
      },
      {
        "level": "lob",
        "dashboard_display_name": "Business Segment Total EAD ($)",
        "in_record": true,
        "sourcing_type": "Agg",
        "level_logic": "For each [L1 Business Segment], SUM(facility.ead) for all facilities under L1 department including all descendant L2/L3 segments via recursive parent_segment_id traversal",
        "source_references": []
      }
    ],
    "number_of_instances": 5,
    "directly_displayed": true,
    "status": "ACTIVE"
  },
  {
    "item_id": "DSCR",
    "item_name": "Debt Service Coverage Ratio",
    "abbreviation": "DSCR",
    "kind": "METRIC",
    "definition": "Net Operating Income (NOI) or EBITDA divided by total debt service obligations. Measures borrower's ability to service debt from operating cash flow. Core CRE underwriting KPI — values below 1.0x indicate insufficient cash flow. Required in FR Y-14Q and CCAR stress testing.",
    "generic_formula": "Cashflow / Total Debt Service",
    "data_type": "Decimal",
    "unit_type": "RATIO",
    "direction": "HIGHER_BETTER",
    "metric_class": "CALCULATED",
    "domain_ids": [
      "FP",
      "CR"
    ],
    "regulatory_references": [
      "CRE underwriting",
      "CCAR",
      "FR Y-14Q"
    ],
    "insight": "Net Operating Income (NOI) or EBITDA divided by total debt service obligations",
    "ingredient_fields": [
      {
        "layer": "L2",
        "table": "facility_financial_snapshot",
        "field": "noi",
        "description": "Net operating income",
        "data_type": "DECIMAL(18,2)",
        "sample_value": "1200000.00"
      },
      {
        "layer": "L2",
        "table": "facility_financial_snapshot",
        "field": "debt_service",
        "description": "Annual total debt service",
        "data_type": "DECIMAL(18,2)",
        "sample_value": "900000.00"
      },
      {
        "layer": "L2",
        "table": "facility_exposure_snapshot",
        "field": "gross_exposure_usd",
        "description": "Gross exposure — weighting basis for rollup",
        "data_type": "DECIMAL(18,2)",
        "sample_value": "5000000.00"
      },
      {
        "layer": "L1",
        "table": "facility_master",
        "field": "counterparty_id",
        "description": "FK to counterparty",
        "data_type": "BIGINT",
        "sample_value": "67890"
      },
      {
        "layer": "L1",
        "table": "facility_master",
        "field": "lob_segment_id",
        "description": "FK to enterprise_business_taxonomy",
        "data_type": "BIGINT",
        "sample_value": "303"
      }
    ],
    "level_definitions": [
      {
        "level": "facility",
        "dashboard_display_name": "Facility DSCR",
        "in_record": true,
        "sourcing_type": "Calc",
        "level_logic": "For each DISTINCT(facility_id) THEN [noi] / [debt_service] from facility_financial_snapshot",
        "source_references": []
      },
      {
        "level": "counterparty",
        "dashboard_display_name": "Counterparty Wtd DSCR",
        "in_record": true,
        "sourcing_type": "Avg",
        "level_logic": "For each [counterparty_id] THEN SUM(facility.dscr * facility.gross_exposure_usd) / SUM(facility.gross_exposure_usd) WHERE IS([counterparty_id])",
        "source_references": []
      },
      {
        "level": "desk",
        "dashboard_display_name": "Desk Wtd DSCR",
        "in_record": true,
        "sourcing_type": "Avg",
        "level_logic": "For each [L3 Business Segment], SUM(facility.dscr * facility.gross_exposure_usd) / SUM(facility.gross_exposure_usd) for all facilities WHERE IS([lob_segment_id])",
        "source_references": []
      },
      {
        "level": "portfolio",
        "dashboard_display_name": "Portfolio Wtd DSCR",
