{
  "name": "data-model-visualizer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3000": "next dev -p 3000",
    "dev:3001": "next dev -p 3001",
    "dev:3002": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "audit": "npm audit",
    "generate:l1": "tsx scripts/l1/generate.ts",
    "generate:l2": "tsx scripts/l2/generate.ts",
    "generate:fk": "tsx scripts/generate-fk-ddl.ts",
    "metric:status": "tsx scripts/metric-status-report.ts",
    "populate:metric-value-fact": "tsx scripts/populate-metric-value-fact.ts",
    "test:metrics": "tsx scripts/test-metrics.ts",
    "test:calc-engine": "tsx scripts/test-calculation-engine.ts",
    "release-tracker:sync": "tsx scripts/release-tracker-sync.ts",
    "release-tracker:init": "tsx scripts/release-tracker-sync.ts --init",
    "hooks:install": "cp scripts/pre-commit-release-tracker.sh $(git rev-parse --git-path hooks)/pre-commit",
    "db:export": "bash scripts/export-mvp-sql.sh",
    "db:export-downloads": "tsx scripts/export-db-to-downloads.ts",
    "db:export-ddl": "tsx scripts/export-ddl-only.ts",
    "db:load-gsib": "tsx scripts/load-gsib-export.ts",
    "db:load-gsib-fresh": "tsx scripts/load-gsib-fresh.ts",
    "db:verify-gsib": "tsx scripts/verify-gsib-load.ts",
    "db:verify-scenarios": "tsx scripts/verify-cro-scenarios.ts",
    "db:migrate": "tsx scripts/migrate-database.ts",
    "db:introspect": "tsx scripts/introspect-db.ts",
    "db:sync-capital": "tsx scripts/sync-capital-db.ts",
    "sync:all": "tsx scripts/sync-all.ts",
    "sync:data-model": "tsx scripts/sync-data-model.ts",
    "export:data-model": "tsx scripts/export-data-model-excel.ts",
    "validate": "tsx scripts/validate-data-model.ts",
    "validate:arch": "tsx scripts/validate-data-model.ts --group=9",
    "validate:l1": "npx tsx scripts/validate-l1-data-quality.ts",
    "lint:sql": "tsx scripts/lint-sql.ts",
    "calc:run": "tsx scripts/calc_engine/cli.ts run",
    "calc:validate": "tsx scripts/calc_engine/cli.ts validate",
    "calc:audit": "tsx scripts/calc_engine/cli.ts audit",
    "calc:inspect": "tsx scripts/calc_engine/cli.ts inspect",
    "calc:list": "tsx scripts/calc_engine/cli.ts list",
    "calc:dag": "tsx scripts/calc_engine/cli.ts dag",
    "calc:sync:excel": "tsx scripts/calc_engine/sync-yaml-to-excel.ts",
    "calc:sync:catalogue": "tsx scripts/calc_engine/sync-yaml-to-catalogue.ts",
    "calc:sync": "npm run calc:sync:excel && npm run calc:sync:catalogue",
    "calc:demo": "tsx scripts/calc_engine/generate-demo-data.ts",
    "calc:demo:all": "tsx scripts/calc_engine/generate-demo-data.ts --all --persist --force",
    "calc:promote": "tsx scripts/calc_engine/cli.ts promote",
    "calc:full": "npm run calc:sync && npm run calc:demo:all",
    "calc:populate-l3": "tsx scripts/calc_engine/populate-l3.ts",
    "factory:generate": "tsx scenarios/factory/scenario-runner.ts --all",
    "factory:generate:one": "tsx scenarios/factory/scenario-runner.ts --scenario",
    "factory:validate": "tsx scenarios/factory/scenario-runner.ts --validate --all",
    "factory:dry-run": "tsx scenarios/factory/scenario-runner.ts --dry-run --all",
    "doc:sync": "tsx scripts/sync-doc-counts.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.42.0",
    "@types/pg-copy-streams": "^1.2.5",
    "ajv": "^8.18.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "next": "^14.2.0",
    "openai": "^6.25.0",
    "pg": "^8.11.3",
    "pg-copy-streams": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.10.3",
    "sql.js": "^1.14.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.2",
    "yargs": "^18.0.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/sql.js": "^1.4.9",
    "@types/xlsx": "^0.0.36",
    "@types/yargs": "^17.0.35",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
